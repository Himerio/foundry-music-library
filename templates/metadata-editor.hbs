<div class="fml-metadata-editor">
  <div class="form-group">
    <label>{{localize "FML.Track.Title"}}</label>
    <input type="text" name="title" value="{{title}}" />
  </div>
  <div class="form-group">
    <label>{{localize "FML.Track.Artist"}}</label>
    <input type="text" name="artist" value="{{artist}}" />
  </div>
  <div class="form-group">
    <label>{{localize "FML.Track.Album"}}</label>
    <input type="text" name="album" value="{{album}}" />
  </div>
  <div class="form-group">
    <label>{{localize "FML.Track.Tags"}}</label>
    <input type="text" name="tags" value="{{tagsText}}" placeholder="{{localize "FML.Metadata.TagsHint"}}" />
  </div>
</div>
